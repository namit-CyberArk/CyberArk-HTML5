#!/bin/bash
# deploy-psmgw-final.sh – Full HTML5 PSM Gateway deployment with certificate fix + hostname resolution

set -e

# ============================================
# USER CONFIGURATION – EDIT THESE VALUES
# ============================================
# Use the FQDN (hostname) that matches your PVWA's SSL certificate
PVWA_HOSTNAME="hostname.yourdomain.local"   # <-- CHANGE THIS
PVWA_IP="IP Of Pvwa"                           # <-- CHANGE THIS (IP address of PVWA)

PSM_HOSTNAME="hostname.yourdomain.local"   # <-- CHANGE THIS
PSM_IP="IP of PSM Server"           # <-- CHANGE THIS (IP address of PVWA)

CONTAINER_NAME="HTML5"   # <-- CHANGE THIS CONTAINER_NAME
NETWORK="cyberark"
HOST_PORT="9443"  # <-- CHANGE THIS Port Number 
CONTAINER_PORT="8443"
CERT_HOST_DIR="/opt/cert"
IMAGE="cahtml5gw:14_2_1_13"  # <-- CHANGE THIS Versions 
# ============================================

# Derived variables
PVWA_URL="https://${PVWA_HOSTNAME}/PasswordVault"
PSM_HOST_MAP="${PVWA_HOSTNAME}:${PVWA_IP}"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

# 1. Create certificate directory if missing
if [ ! -d "$CERT_HOST_DIR" ]; then
    log_info "Creating $CERT_HOST_DIR..."
    sudo mkdir -p "$CERT_HOST_DIR"
fi

# 2. Fetch PVWA certificate using the hostname (not IP)
log_info "Fetching PVWA certificate from https://${PVWA_HOSTNAME}:443 ..."
sudo openssl s_client -connect "${PVWA_HOSTNAME}:443" -showcerts </dev/null 2>/dev/null | \
    awk '/BEGIN CERTIFICATE/,/END CERTIFICATE/' | sudo tee "$CERT_HOST_DIR/pvwa-ca.pem" > /dev/null

if [ ! -s "$CERT_HOST_DIR/pvwa-ca.pem" ]; then
    log_error "Failed to fetch certificate from ${PVWA_HOSTNAME}. Check network and DNS resolution."
fi
log_info "Certificate saved to $CERT_HOST_DIR/pvwa-ca.pem"

# 3. Remove old container and systemd service
if podman ps -a --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
    log_info "Stopping and removing existing container $CONTAINER_NAME..."
    podman stop "$CONTAINER_NAME" 2>/dev/null || true
    podman rm "$CONTAINER_NAME" 2>/dev/null || true
fi

SERVICE_FILE="/etc/systemd/system/container-${CONTAINER_NAME}.service"
if [ -f "$SERVICE_FILE" ]; then
    log_info "Removing old systemd service..."
    sudo rm -f "$SERVICE_FILE"
    sudo systemctl daemon-reload
fi

# 4. Launch container with hostname resolution and correct PVWA URL
log_info "Launching new container with hostname $PVWA_HOSTNAME ..."
sudo podman run -d \
    --name "$CONTAINER_NAME" \
    --hostname "$CONTAINER_NAME" \
    --network "$NETWORK" \
    -p "${HOST_PORT}:${CONTAINER_PORT}" \
    -v "${CERT_HOST_DIR}:/opt/import:ro,Z" \
    --add-host "$PSM_HOST_MAP" \
    --add-host "${PSM_HOSTNAME}:${PSM_IP}" \
    -e AcceptCyberArkEULA=yes \
    -e PSMGWAppLogLevel=debug \
    -e PSMGWGuacLogLevel=debug \
    -e EndPointAddress="$PVWA_URL" \
    -e IgnorePSMCertificateErrors=yes \
    "$IMAGE"

# 5. Wait and verify certificate import
log_info "Waiting 10 seconds for container to start..."
sleep 10

log_info "=== Certificate import status ==="
sudo podman logs "$CONTAINER_NAME" 2>&1 | grep -E "added certificate|SUCCESS.*certificate|unable to load" | tail -20

log_info "=== Checking for JWT/PKIX errors ==="
sleep 2
if sudo podman logs "$CONTAINER_NAME" 2>&1 | grep -qi "pkix\|jwt.*fail\|subject alternative"; then
    log_warn "Some errors still present. Please check full logs:"
    sudo podman logs --tail 50 "$CONTAINER_NAME"
else
    log_info "No JWT/PKIX errors detected in logs."
fi

log_info "✅ Deployment complete."
log_info "PVWA URL used: $PVWA_URL"
log_info "Host mapping added: $PSM_HOST_MAP"
log_info ""
log_info "➡️  Try launching an HTML5 session from PVWA."
log_info "➡️  If still fails, check: sudo podman logs $CONTAINER_NAME | grep -i 'error'"
